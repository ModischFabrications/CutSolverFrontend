{
    email {$EMAIL_ADDRESS}
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory

    admin off
    log {
        format console
    }
}

{$DOMAIN_NAME} {
    encode zstd gzip

    header /ping Content-Type text/plain
    respond /ping "pong at {$DOMAIN_NAME}" 200
    
    # API paths -> backend
    @api path /solve* /version* /constants* /settings* /debug* /docs* /redoc* /openapi.json*
    reverse_proxy @api cutsolver:80
    
    # Everything else -> frontend
    reverse_proxy cutsolver_frontend:80
}

# Legacy redirect
vps.modisch.me {
    redir /cutsolver https://{$DOMAIN_NAME} permanent
}
